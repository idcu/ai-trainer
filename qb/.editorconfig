# Editor configuration
# See https://editorconfig.org for more details

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
max_line_length = 80
trim_trailing_whitespace = false

[*.html]
indent_size = 2

[*.css]
indent_size = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf
