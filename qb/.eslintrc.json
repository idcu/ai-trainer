{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-empty": "warn",
    "no-debugger": "warn",
    "eqeqeq": ["warn", "always"],
    "curly": ["warn", "all"],
    "brace-style": ["warn", "1tbs"],
    "indent": ["warn", 4, { "SwitchCase": 1 }],
    "linebreak-style": ["warn", "unix"],
    "quotes": ["warn", "single"],
    "semi": ["warn", "always"],
    "comma-dangle": ["warn", "never"],
    "no-trailing-spaces": "warn",
    "eol-last": ["warn", "always"]
  },
  "globals": {
    "CONFIG": "readonly",
    "QuizEngine": "readonly",
    "UIRenderer": "readonly",
    "WrongBook": "readonly",
    "Favorites": "readonly",
    "History": "readonly",
    "SearchFilter": "readonly",
    "ProgressSaver": "readonly",
    "DataIO": "readonly",
    "Statistics": "readonly",
    "Storage": "readonly",
    "Helpers": "readonly",
    "DataLoader": "readonly"
  }
}
